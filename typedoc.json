{
  "$schema": "https://typedoc.org/schema.json",
  "name": "Sigil API",
  "entryPoints": [
    "packages/core",
    "packages/shortcode",
    "packages/editor",
    "packages/ui",
    "packages/blocks",
    "packages/store-json"
  ],
  "entryPointStrategy": "packages",
  "packageOptions": {
    "entryPoints": ["src/index.ts"],
    "tsconfig": "tsconfig.json",
    "readme": "none"
  },
  "plugin": ["typedoc-plugin-markdown"],
  "out": "docs/api",
  "readme": "none",
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "skipErrorChecking": true,
  "githubPages": false,
  "hideGenerator": true,
  "router": "module",
  "outputs": [
    {
      "name": "markdown",
      "path": "docs/api"
    }
  ]
}
